        "sell-large": "ts-node src/scripts/sellLargePositions.ts",
        "redeem-resolved": "ts-node src/scripts/redeemResolvedPositions.ts",
        "fetch-history": "ts-node src/scripts/fetchHistoricalTrades.ts",
        "simulate": "ts-node src/scripts/simulateProfitability.ts",
        "check-stats": "ts-node src/scripts/checkMyStats.ts",
        "find-traders": "ts-node src/scripts/findBestTraders.ts",
